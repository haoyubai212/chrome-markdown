{
  "manifest_version": 3,
  "name": "Local MD Reader",
  "description": "A private, fully local Markdown file and folder reader.",
  "version": "0.3.2",
  "minimum_chrome_version": "109",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Local MD Reader",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["file-handler.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "assets/*"],
      "matches": ["file:///*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' file:; img-src 'self' blob: data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'"
  }
}
